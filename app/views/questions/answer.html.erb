<h1>Your question:</h1>
<p><%= @question %></p>

<h1>Coach's answer:</h1>
<p>
  <% if @question == "I am going to work" %>
    Great!
  <% elsif @question.end_with?("?") %>
    Silly question, get dressed and go to work!
  <% else %>
    I don't care, get dressed and go to work!
  <% end %>
</p>

<%= link_to "Ask a new question", ask_path %>
